{
	"name": "purple-currency-converter",
	"version": "0.11.0",
	"private": true,
	"description": "Currency conversion API with live exchange rates — Purple LAB case study",
	"type": "module",
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"dev": "node --env-file=.env --import tsx src/server.ts",
		"typecheck": "tsc --noEmit",
		"lint:api": "eslint .",
		"format:api": "prettier --write .",
		"test:api": "vitest run",
		"verify:api": "npm run typecheck && npm run lint:api && npm run test:api",
		"db:init": "node --env-file=.env --import tsx scripts/create-local-table.ts",
		"setup": "node --import tsx scripts/setup.ts",
		"openapi:export": "node --import tsx scripts/openapi-export.ts"
	},
	"dependencies": {
		"@aws-sdk/client-dynamodb": "^3.1067.0",
		"@aws-sdk/lib-dynamodb": "^3.1067.0",
		"@fastify/aws-lambda": "^6.4.0",
		"@fastify/cors": "^11.2.0",
		"@fastify/helmet": "^13.0.2",
		"@fastify/rate-limit": "^11.0.0",
		"@fastify/swagger": "^9.7.0",
		"@fastify/swagger-ui": "^6.0.0",
		"fastify": "^5.8.5",
		"fastify-type-provider-zod": "^6.1.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/aws-lambda": "^8.10.162",
		"@types/node": "^25.9.3",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"prettier": "^3.8.4",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.0",
		"vitest": "^4.1.8"
	}
}
