{
	"name": "purple-currency-converter-web",
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"dev": "vite",
		"build": "tsc --noEmit && vite build",
		"preview": "vite preview",
		"typecheck": "tsc --noEmit",
		"lint:web": "eslint .",
		"format:web": "prettier --write .",
		"test:web": "vitest run",
		"verify:web": "npm run typecheck && npm run lint:web && npm run test:web",
		"generate:api": "orval"
	},
	"dependencies": {
		"@fontsource/roboto": "^5.2.10",
		"axios": "^1.17.0",
		"i18next": "^26.3.1",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-hook-form": "^7.78.0",
		"react-i18next": "^17.0.8"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.2",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"jsdom": "^29.1.1",
		"orval": "^8.17.0",
		"prettier": "^3.8.4",
		"sass": "^1.101.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.0",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	}
}
